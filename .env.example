# === Runtime ===
APP_ENV=development
AUTO_CREATE_TABLES=1

# === Database ===
# Preferred: set DATABASE_URL directly.
# DATABASE_URL=postgresql://postgres:change-this-postgres-password@localhost:5432/atmr_db
DB_USER=postgres
DB_PASSWORD=change-this-postgres-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atmr_db

# === Docker images / package mirrors ===
# If Docker Hub is slow, point POSTGRES_IMAGE to your own registry mirror.
POSTGRES_IMAGE=postgres:15-alpine
PYTHON_IMAGE=python:3.10-slim
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_DEFAULT_TIMEOUT=300
PIP_RETRIES=10
REQUIREMENTS_FILE=requirements_full.txt

# === JWT ===
SECRET_KEY=change-this-to-a-random-string

# === CORS ===
ALLOWED_ORIGINS=*

# === AI keys ===
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
