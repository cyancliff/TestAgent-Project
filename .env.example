# === 运行环境 ===
# development = 开发模式（允许默认密钥），production = 生产模式（强制密钥检查）
APP_ENV=development

# === 数据库密码（必填，请修改为你自己的密码）===
DB_PASSWORD=testagent2026

# === JWT 密钥（必填，请修改为一个随机字符串）===
SECRET_KEY=change-this-to-a-random-string

# === 前端跨域白名单（逗号分隔，* 表示放行所有）===
ALLOWED_ORIGINS=*

# === AI 功能密钥（选填，不填则 AI 对话功能不可用）===
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
